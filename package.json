{
  "name": "@poamslayer/ecfr",
  "version": "0.1.0",
  "description": "CLI for the Electronic Code of Federal Regulations (eCFR) API",
  "type": "module",
  "bin": {
    "ecfr": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ecfr",
    "cfr",
    "federal-regulations",
    "compliance",
    "cmmc",
    "nist"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arnoldd98/ecfr"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.5.9"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
